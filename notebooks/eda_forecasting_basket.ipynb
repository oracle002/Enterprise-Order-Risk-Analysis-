    }
   },
   "outputs": [],
   "source": [
    "# Simple exponential smoothing for fraud & return rate (noisier, less seasonal signal)\n",
    "hw_fraud = ExponentialSmoothing(monthly[\"fraud_rate\"], trend=\"add\").fit()\n",
    "hw_return = ExponentialSmoothing(monthly[\"return_rate\"], trend=\"add\").fit()\n",
    "fraud_forecast = hw_fraud.forecast(forecast_horizon)\n",
    "return_forecast = hw_return.forecast(forecast_horizon)"
   ]
  },
